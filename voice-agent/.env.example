# ─────────────────────────────────────────────────────────────────────────────
# voice-agent — environment configuration (LiveKit Agents, Python worker)
#
# Copy to `.env` and fill in real values:   cp .env.example .env
# This worker is a SEPARATE deployable from the Node app. It owns ONLY the
# real-time audio loop and delegates every turn to the Node brain over HTTP.
# ─────────────────────────────────────────────────────────────────────────────

# ── Node brain delegation (USED NOW by delegate_turn() in agent.py) ──────────
# Base URL of the Node app that owns all business logic. Every transcribed turn
# is POSTed to `${NODE_BRAIN_URL}/internal/voice/turn`.
NODE_BRAIN_URL=http://localhost:3000

# Shared HMAC secret. MUST match VOICE_INTERNAL_SECRET in the Node app's .env —
# the worker signs each request body (sha256=<hexdigest>) and the Node endpoint
# verifies it. Requests are rejected 401 if this is empty or mismatched.
VOICE_INTERNAL_SECRET=

# Per-turn HTTP timeout (seconds) when calling the Node brain. Optional.
VOICE_TURN_TIMEOUT_S=10

# ── Sarvam STT/TTS (USED NOW by the audio loop once wiring is implemented) ───
# Sarvam Saaras (STT) + Bulbul (TTS) subscription key.
SARVAM_API_KEY=

# ── LiveKit Cloud (REQUIRED once the LiveKit Agents wiring is implemented) ───
# The skeleton in agent.py does NOT read these yet — the `cli.run_app(...)`
# entrypoint (documented inline in agent.py) reads them from the environment
# when implemented (PR7). The LiveKit SDK looks for these exact names.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
