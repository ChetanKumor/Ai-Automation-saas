# ─────────────────────────────────────────────────────────────────────────────
# voice-agent — environment configuration (LiveKit Agents, Python worker)
#
# Copy to `.env` and fill in real values:   cp .env.example .env
# This worker is a SEPARATE deployable from the Node app. It owns ONLY the
# real-time audio loop and delegates every turn to the Node brain over HTTP.
#
# Dev run profile (local dev room, telephony noop):
#   uv sync && uv run agent.py dev        # or: python agent.py dev
# ─────────────────────────────────────────────────────────────────────────────

# ── Node brain delegation (call/start, turn, call/end) ───────────────────────
# Base URL of the Node app that owns ALL business logic. Each call bridges via
# ${NODE_BRAIN_URL}/internal/voice/call/start and every turn via .../turn.
NODE_BRAIN_URL=http://localhost:3000

# Shared HMAC secret. MUST match VOICE_INTERNAL_SECRET in the Node app's .env —
# the worker signs each request body (sha256=<hexdigest>) and Node verifies it.
# Requests are rejected 401 if this is empty or mismatched.
VOICE_INTERNAL_SECRET=

# Per-turn HTTP timeout (seconds) for delegate_turn. On timeout the worker
# speaks a static per-language apology (never dead air) and ends the call
# status='failed'. In SSE mode (below) this becomes the PER-CHUNK read timeout.
VOICE_TURN_TIMEOUT_S=10

# ── PR9C: opt-in SSE turn streaming (dark by default) ────────────────────────
# true  -> turns are delegated in SSE mode: the brain-authored ack is spoken
#          the moment a tool round starts, and the final reply streams into TTS
#          as it is generated (first audio at first-token, not last-token).
# false -> today's JSON path, byte-identical (instant rollback switch).
VOICE_STREAM_TURNS=false

# Overall hard cap (seconds) for one SSE turn — a stream that drips past this
# is cut off with the static apology. Per-chunk stalls are caught earlier by
# VOICE_TURN_TIMEOUT_S.
VOICE_TURN_MAX_S=60

# ── Local call context (dev room has no carrier caller id) ───────────────────
# The tenant whose brain handles the call, and the caller number to resolve.
# VOICE_DEV_CALLER_NUMBER must match the seeded returning customer:
#   node scripts/seed_voice_test_customer.js
VOICE_TENANT_ID=11111111-1111-1111-1111-111111111111
VOICE_DEV_CALLER_NUMBER=+919000000001

# ── Sarvam STT/TTS (official LiveKit plugin) ─────────────────────────────────
# Sarvam Saaras (STT) + Bulbul (TTS) subscription key.
SARVAM_API_KEY=

# Models / voice (defaults shown). SARVAM_TTS_SPEAKER must be valid for
# bulbul:v3 — e.g. shubh, ritu, rahul, pooja, kavya, amit, ishita, shreya,
# priya, aditya, neha, varun, suhani, rupali, tanya, shruti, kavitha.
SARVAM_STT_MODEL=saaras:v3
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=shubh

# Default spoken language when no per-call prior is provided (BCP-47).
# STT auto-detects the caller's language; the brain replies in-language.
VOICE_DEFAULT_LANGUAGE=te-IN

# ── LiveKit Cloud (REQUIRED to run the worker) ───────────────────────────────
# The LiveKit Agents CLI reads these exact names from the environment.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
