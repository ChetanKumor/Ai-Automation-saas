# Copy to .env and fill in. .env is gitignored; this file must never hold real
# secrets. Only the six vars under "Required" are enforced at boot by
# src/infra/config/env.js — everything else is optional with a safe default.

# ── Required ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
GEMINI_API_KEY=
WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=
# 32-byte hex (64 chars) for AES-256-GCM of tenants.wa_token: openssl rand -hex 32
ENCRYPTION_KEY=
ADMIN_PASSWORD=

# ── Tests ───────────────────────────────────────────────────────────────────
# Point the test suite at a LOCAL Postgres. When set, `npm test` uses this
# instead of DATABASE_URL for everything: the base-DB suites, and the scratch
# databases the integration suites CREATE/genesis/DROP per file. Resolved in
# exactly one place — tests/_support/testEnv.js, loaded via --require.
#
# Unset is still supported: the suite falls back to DATABASE_URL (today's
# behavior) and prints a loud warning, because a remote DB makes the suite
# nondeterministic — connection latency against the 5s statement timeout is what
# TEST-FLAKE-02 fixed.
#
# The role must be able to CREATE DATABASE / DROP DATABASE, and the server needs
# the pgvector extension available (schema.sql declares `CREATE EXTENSION vector`
# plus an hnsw index; genesis fails without it).
#
# One-time setup of the base database:
#   createdb saas_crm_test
#   DATABASE_URL="<the value below>" npm run db:genesis
TEST_DATABASE_URL=postgres://postgres:password@localhost:5432/saas_crm_test

# ── Server ──────────────────────────────────────────────────────────────────
# NODE_ENV=production must be set explicitly in prod — it gates trust-proxy and
# secure cookies.
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
# Both optional; if set, must be >= 32 chars.
SESSION_SECRET=
PORTAL_SESSION_SECRET=

# ── Feature flags (off by default) ──────────────────────────────────────────
IDENTITY_RESOLUTION_ENABLED=false
# Patient-facing reputational risk — leave off unless deliberately enabled.
COLLECTIONS_ENABLED=false

# ── Voice channel (PR6/PR7) — all optional, nothing wires up when off ───────
VOICE_ENABLED=false
TELEPHONY_PROVIDER=noop
SARVAM_API_KEY=
SARVAM_BASE_URL=
VOICE_INTERNAL_SECRET=

# Voice turn latency knobs (PR9A) — voice channel only; WhatsApp is untouched.
VOICE_THINKING_BUDGET=0
VOICE_MAX_OUTPUT_TOKENS=150
VOICE_HISTORY_TURNS=8
VOICE_MEMORY_FACTS_MAX=10

# ── Timeouts (Issue 29) ─────────────────────────────────────────────────────
# TURN_BUDGET_MS must stay strictly BELOW the worker's VOICE_TURN_TIMEOUT_S
# (voice-agent/agent.py, default 10s) — change them together.
TURN_BUDGET_MS=8000
# Postgres statement_timeout for the app pool. The migration runner uses its own
# client and is deliberately exempt.
DB_STATEMENT_TIMEOUT_MS=5000

# ── Local dev/scripts only ──────────────────────────────────────────────────
VOICE_TENANT_ID=
VOICE_DEV_CALLER_NUMBER=
VOICE_DEV_PHONE_NUMBER_ID=
TEST_TENANT_PHONE_ID=
TEST_CUSTOMER_PHONE=
CHROME_PATH=
